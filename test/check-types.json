{
  "target": "../schemas/schema.json",
  "$comment": "Check type tests",
  "tests": [
    {
      "description": "Service with integration check - to be deprecated in the future",
      "valid": true,
      "data": {
        "services": [
          {
            "service-tag": "generic-service",
            "quality-gates": [
              {
                "check-types": ["integration"],
                "provider": "GitHub",
                "phase": "pre-merge",
                "config": {
                  "file": ".github/workflows/tests.yaml",
                  "path": "jobs.unit",
                  "jobName": "Run unit tests"
                }
              }
            ]
          }
        ]
      }
    },
