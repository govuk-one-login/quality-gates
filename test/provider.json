{
  "target": "../schemas/schema.json",
  "$comment": "provider validation tests",
  "tests": [
    {
      "description": "valid provider GitHub",
      "valid": true,
      "data": {
        "services": [
          {
            "serviceTag": "service",
            "promotionType": "securePipelines",
            "checks": [
              {
                "checkTypes": ["unit"],
                "provider": "GitHub",
                "phase": "pre-merge",
                "config": {
                  "file": ".github/workflows/test.yaml",
                  "path": "$.jobs.test"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "description": "valid provider Terraform",
      "valid": true,
      "data": {
        "services": [
          {
            "serviceTag": "service",
            "promotionType": "securePipelines",
            "checks": [
              {
                "checkTypes": ["unit"],
                "provider": "Terraform",
                "phase": "pre-merge",
                "config": {
                  "file": "terraform/main.tf"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "description": "valid provider CloudFormation",
      "valid": true,
      "data": {
        "services": [
          {
            "serviceTag": "service",
            "promotionType": "securePipelines",
            "checks": [
              {
                "checkTypes": ["unit"],
                "provider": "CloudFormation",
                "phase": "pre-merge",
                "config": {
                  "file": "template.yaml"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "description": "valid provider Stack Orchestration Tool",
      "valid": true,
      "data": {
        "services": [
          {
            "serviceTag": "service",
            "promotionType": "securePipelines",
            "checks": [
              {
                "checkTypes": ["unit"],
                "provider": "Stack Orchestration Tool",
                "phase": "pre-merge",
                "config": {
                  "file": "ci/parameters.json"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "description": "invalid provider Jenkins",
      "valid": false,
      "data": {
        "services": [
          {
            "serviceTag": "service",
            "promotionType": "securePipelines",
            "checks": [
              {
                "checkTypes": ["unit"],
                "provider": "Jenkins",
                "phase": "pre-merge",
                "config": {
                  "file": ".github/workflows/test.yaml",
                  "path": "$.jobs.test"
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
