{
  "target": "../schemas/schema.json",
  "$comment": "GitHub Library SDK tests",
  "tests": [
    {
      "description": "Library",
      "valid": true,
      "data": {
        "services": [
          {
            "serviceTag": "generic-library",
            "promotionType": "library",
            "qualityGates": [
              {
                "checkType": "unit",
                "provider": "GitHub",
                "phase": "pre-merge",
                "file": ".github/workflows/tests.yaml",
                "path": "jobs.unit"
              },
              {
                "checkType": "unit",
                "provider": "GitHub",
                "phase": "pre-release",
                "file": ".github/workflows/tests.yaml",
                "path": "jobs.unit"
              }
            ]
          }
        ]
      }
    }
  ]
}
