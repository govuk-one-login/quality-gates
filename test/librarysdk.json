{
  "target": "../schemas/schema.json",
  "$comment": "GitHub Library SDK tests",
  "tests": [
    {
      "description": "Library",
      "valid": true,
      "data": {
        "services": [
          {
            "serviceTag": "generic-library",
            "promotionType": "library",
            "checks": [
              {
                "checkTypes": ["unit"],
                "provider": "GitHub",
                "phase": "pre-merge",
                "config": {
                  "file": ".github/workflows/tests.yaml",
                  "path": "jobs.unit",
                  "jobName": "Run unit tests"
                }
              },
              {
                "checkTypes": ["unit"],
                "provider": "GitHub",
                "phase": "pre-release",
                "config": {
                  "file": ".github/workflows/tests.yaml",
                  "path": "jobs.unit",
                  "jobName": "Run unit tests"
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
