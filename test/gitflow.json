{
  "target": "../schemas/schema.json",
  "$comment": "GitHub GitFlow tests",
  "tests": [
    {
      "description": "Service with gitflow",
      "valid": true,
      "data": {
        "services": [
          {
            "serviceTag": "generic-service",
            "promotionType": "gitFlow",
            "qualityGates": [
              {
                "checkType": "unit",
                "provider": "GitHub",
                "phase": "pre-develop",
                "file": ".github/workflows/tests.yaml",
                "path": "jobs.unit"
              },
              {
                "checkType": "unit",
                "provider": "GitHub",
                "phase": "develop",
                "file": ".github/workflows/tests.yaml",
                "path": "jobs.unit"
              },
              {
                "checkType": "unit",
                "provider": "GitHub",
                "phase": "pre-release",
                "file": ".github/workflows/tests.yaml",
                "path": "jobs.unit"
              },
              {
                "checkType": "unit",
                "provider": "GitHub",
                "phase": "release",
                "file": ".github/workflows/tests.yaml",
                "path": "jobs.unit"
              },
              {
                "checkType": "unit",
                "provider": "GitHub",
                "phase": "main",
                "file": ".github/workflows/tests.yaml",
                "path": "jobs.unit"
              }
            ]
          }
        ]
      }
    }
  ]
}
