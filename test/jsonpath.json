{
  "target": "../schemas/schema.json",
  "$comment": "JSONPath config.path validation tests",
  "tests": [
    {
      "description": "Valid JSONPath: $.jobs.test",
      "valid": true,
      "data": {
        "services": [
          {
            "product": "service",
            "component": "api",
            "promotionType": "securePipelines",
            "checks": [
              {
                "checkTypes": ["unit"],
                "provider": "GitHub",
                "phase": "pre-merge",
                "config": {
                  "file": ".github/workflows/test.yml",
                  "path": "$.jobs.test"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "description": "Valid JSONPath: bracket notation $.jobs['my-job']",
      "valid": true,
      "data": {
        "services": [
          {
            "product": "service",
            "component": "api",
            "promotionType": "securePipelines",
            "checks": [
              {
                "checkTypes": ["unit"],
                "provider": "GitHub",
                "phase": "pre-merge",
                "config": {
                  "file": ".github/workflows/test.yml",
                  "path": "$.jobs['my-job']"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "description": "Valid JSONPath: step filter by name",
      "valid": true,
      "data": {
        "services": [
          {
            "product": "service",
            "component": "api",
            "promotionType": "securePipelines",
            "checks": [
              {
                "checkTypes": ["unit"],
                "provider": "GitHub",
                "phase": "pre-merge",
                "config": {
                  "file": ".github/workflows/test.yml",
                  "path": "$.jobs.build.steps[?@.name=='Run tests']"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "description": "Valid JSONPath: Stack Orchestration Tool filter",
      "valid": true,
      "data": {
        "services": [
          {
            "product": "service",
            "component": "api",
            "promotionType": "securePipelines",
            "checks": [
              {
                "checkTypes": ["integration"],
                "provider": "Stack Orchestration Tool",
                "phase": "build",
                "config": {
                  "file": "ci/stack-orchestration/parameters.json",
                  "path": "$[?@.ParameterKey=='X']"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "description": "Invalid: path without $ prefix",
      "valid": false,
      "data": {
        "services": [
          {
            "product": "service",
            "component": "api",
            "promotionType": "securePipelines",
            "checks": [
              {
                "checkTypes": ["unit"],
                "provider": "GitHub",
                "phase": "pre-merge",
                "config": {
                  "file": ".github/workflows/test.yml",
                  "path": "jobs.test"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "description": "Invalid: file with colon (external reference)",
      "valid": false,
      "data": {
        "services": [
          {
            "product": "service",
            "component": "api",
            "promotionType": "securePipelines",
            "checks": [
              {
                "checkTypes": ["unit"],
                "provider": "Terraform",
                "phase": "build",
                "config": {
                  "file": "other-repo:terraform/main.tf"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "description": "Valid: Terraform check without path",
      "valid": true,
      "data": {
        "services": [
          {
            "product": "service",
            "component": "api",
            "promotionType": "securePipelines",
            "checks": [
              {
                "checkTypes": ["integration"],
                "provider": "Terraform",
                "phase": "build",
                "config": {
                  "file": "terraform/main.tf"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "description": "Valid: GitHub check without path",
      "valid": true,
      "data": {
        "services": [
          {
            "product": "service",
            "component": "api",
            "promotionType": "securePipelines",
            "checks": [
              {
                "checkTypes": ["unit"],
                "provider": "GitHub",
                "phase": "pre-merge",
                "config": {
                  "file": ".github/workflows/test.yml"
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
