{
  "target": "../schemas/schema.json",
  "$comment": "promotionType other with promotionTypeDetails tests",
  "tests": [
    {
      "description": "other with promotionTypeDetails and custom phase is valid",
      "valid": true,
      "data": {
        "services": [
          {
            "serviceTag": "service",
            "promotionType": "other",
            "promotionTypeDetails": ["custom pipeline"],
            "checks": [
              {
                "checkTypes": ["unit"],
                "provider": "GitHub",
                "phase": "my-custom-phase",
                "config": {
                  "file": ".github/workflows/test.yaml",
                  "path": "$.jobs.test"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "description": "other with multiple promotionTypeDetails is valid",
      "valid": true,
      "data": {
        "services": [
          {
            "serviceTag": "service",
            "promotionType": "other",
            "promotionTypeDetails": ["custom pipeline", "manual approval"],
            "checks": [
              {
                "checkTypes": ["unit"],
                "provider": "GitHub",
                "phase": "deploy-canary",
                "config": {
                  "file": ".github/workflows/test.yaml",
                  "path": "$.jobs.test"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "description": "other with phase value from another promotionType is valid",
      "valid": true,
      "data": {
        "services": [
          {
            "serviceTag": "service",
            "promotionType": "other",
            "promotionTypeDetails": ["custom deployment tool"],
            "checks": [
              {
                "checkTypes": ["unit"],
                "provider": "GitHub",
                "phase": "staging",
                "config": {
                  "file": ".github/workflows/test.yaml",
                  "path": "$.jobs.test"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "description": "other without promotionTypeDetails is invalid",
      "valid": false,
      "data": {
        "services": [
          {
            "serviceTag": "service",
            "promotionType": "other",
            "checks": [
              {
                "checkTypes": ["unit"],
                "provider": "GitHub",
                "phase": "deploy",
                "config": {
                  "file": ".github/workflows/test.yaml",
                  "path": "$.jobs.test"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "description": "other with empty promotionTypeDetails is invalid",
      "valid": false,
      "data": {
        "services": [
          {
            "serviceTag": "service",
            "promotionType": "other",
            "promotionTypeDetails": [],
            "checks": [
              {
                "checkTypes": ["unit"],
                "provider": "GitHub",
                "phase": "deploy",
                "config": {
                  "file": ".github/workflows/test.yaml",
                  "path": "$.jobs.test"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "description": "other with non-string in promotionTypeDetails is invalid",
      "valid": false,
      "data": {
        "services": [
          {
            "serviceTag": "service",
            "promotionType": "other",
            "promotionTypeDetails": [123],
            "checks": [
              {
                "checkTypes": ["unit"],
                "provider": "GitHub",
                "phase": "deploy",
                "config": {
                  "file": ".github/workflows/test.yaml",
                  "path": "$.jobs.test"
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
