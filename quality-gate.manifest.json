{
  "$schema": "./schemas/schema.json",
  "services": [
    {
      "serviceTag": "quality-gates",
      "promotionType": "library",
      "qualityGates": [
        {
          "checkTypes": ["unit"],
          "phase": "pre-merge",
          "provider": "GitHub",
          "config": {
            "file": "./workflows/schema.yml",
            "path": "jobs.run-tests"
          }
        },
        {
          "checkTypes": ["unit"],
          "phase": "pre-merge",
          "provider": "GitHub",
          "config": {
            "file": "./workflows/visualiser.yml",
            "path": "jobs.run-tests"
          }
        },
        {
          "checkTypes": ["code quality"],
          "phase": "pre-merge",
          "provider": "GitHub",
          "config": {
            "file": "./workflows/quality.yml",
            "path": "jobs.codeql"
          }
        },
        {
          "checkTypes": ["code style and linting"],
          "phase": "pre-merge",
          "provider": "GitHub",
          "config": {
            "file": "./workflows/quality.yml",
            "path": "jobs.pre-commit"
          }
        }
      ]
    }
  ]
}
