{
  "$schema": "./schemas/schema.json",
  "services": [
    {
      "serviceTag": "quality-gates",
      "promotionType": "library",
      "qualityGates": [
        {
          "checkType": "unit",
          "phase": "pre-merge",
          "provider": "GitHub",
          "file": "./github/workflows/schema.yml",
          "path": "jobs.run-tests"
        },
        {
          "checkType": "unit",
          "phase": "pre-merge",
          "provider": "GitHub",
          "file": ".github/workflows/visualiser.yml",
          "path": "jobs.run-tests"
        },
        {
          "checkType": "code quality",
          "phase": "pre-merge",
          "provider": "GitHub",
          "file": ".github/workflows/quality.yml",
          "path": "jobs.codeql"
        },
        {
          "checkType": "code style and linting",
          "phase": "pre-merge",
          "provider": "GitHub",
          "file": ".github/workflows/quality.yml",
          "path": "jobs.pre-commit"
        }
      ]
    }
  ]
}
