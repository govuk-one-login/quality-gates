{
  "services": [
    {
      "serviceTag": "service-name",
      "promotionType": "securePipelines",
      "checks": [
        {
          "checkTypes": ["code style and linting"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/check-code-quality.yaml",
            "path": "$.jobs.pre-commit"
          }
        },
        {
          "checkTypes": ["code style and linting"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/check-code-quality.yaml",
            "path": "$.jobs.gitlint"
          }
        },
        {
          "checkTypes": ["code style and linting"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/check-code-quality.yaml",
            "path": "$.jobs.checkov"
          }
        }
      ]
    }
  ]
}
