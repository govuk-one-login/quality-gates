{
  "services": [
    {
      "serviceTag": "service-name",
      "promotionType": "securePipelines",
      "qualityGates": [
        {
          "checkType": "unit",
          "provider": "GitHub",
          "phase": "pre-merge",
          "file": ".github/workflows/check-code-quality.yaml",
          "path": "jobs.pre-commit"
        },
        {
          "checkType": "unit",
          "provider": "GitHub",
          "phase": "pre-merge",
          "file": ".github/workflows/check-code-quality.yaml",
          "path": "jobs.gitlint"
        },
        {
          "checkType": "unit",
          "provider": "GitHub",
          "phase": "pre-merge",
          "file": ".github/workflows/check-code-quality.yaml",
          "path": "jobs.checkov"
        }
      ]
    }
  ]
}
