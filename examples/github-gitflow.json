{
  "services": [
    {
      "serviceTag": "service-name",
      "promotionType": "gitFlow",
      "qualityGates": [
        {
          "checkType": "unit",
          "provider": "GitHub",
          "phase": "pre-develop",
          "file": ".github/workflows/lint.yaml",
          "path": "jobs.lint"
        },
        {
          "checkType": "unit",
          "provider": "GitHub",
          "phase": "develop",
          "file": ".github/workflows/lint.yaml",
          "path": "jobs.lint"
        },
        {
          "checkType": "unit",
          "provider": "GitHub",
          "phase": "pre-release",
          "file": ".github/workflows/lint.yaml",
          "path": "jobs.lint"
        },
        {
          "checkType": "unit",
          "provider": "GitHub",
          "phase": "pre-release",
          "file": ".github/workflows/lint.yaml",
          "path": "jobs.lint"
        },
        {
          "checkType": "unit",
          "provider": "GitHub",
          "phase": "main",
          "file": ".github/workflows/lint.yaml",
          "path": "jobs.lint"
        }
      ]
    }
  ]
}
