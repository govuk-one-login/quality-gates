{
  "services": [
    {
      "serviceTag": "service-name",
      "promotionType": "gitFlow",
      "qualityGates": [
        {
          "checkTypes": ["unit"],
          "provider": "GitHub",
          "phase": "pre-develop",
          "config": {
            "file": ".github/workflows/lint.yaml",
            "name": "Lint"
          }
        },
        {
          "checkTypes": ["unit"],
          "provider": "GitHub",
          "phase": "develop",
          "config": {
            "file": ".github/workflows/lint.yaml",
            "name": "Lint"
          }
        },
        {
          "checkTypes": ["unit"],
          "provider": "GitHub",
          "phase": "pre-release",
          "config": {
            "file": ".github/workflows/lint.yaml",
            "name": "Lint"
          }
        },
        {
          "checkTypes": ["unit"],
          "provider": "GitHub",
          "phase": "pre-release",
          "config": {
            "file": ".github/workflows/lint.yaml",
            "name": "Lint"
          }
        },
        {
          "checkTypes": ["unit"],
          "provider": "GitHub",
          "phase": "main",
          "config": {
            "file": ".github/workflows/lint.yaml",
            "name": "Lint"
          }
        }
      ]
    }
  ]
}
