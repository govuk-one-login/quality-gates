{
  "services": [
    {
      "serviceTag": "service-name",
      "promotionType": "gitFlow",
      "checks": [
        {
          "checkTypes": ["code style and linting"],
          "provider": "GitHub",
          "phase": "pre-develop",
          "config": {
            "file": ".github/workflows/lint.yaml",
            "path": "$.jobs.lint"
          }
        },
        {
          "checkTypes": ["unit"],
          "provider": "GitHub",
          "phase": "develop",
          "config": {
            "file": ".github/workflows/tests.yaml",
            "path": "$.jobs.unit"
          }
        },
        {
          "checkTypes": ["integration"],
          "provider": "GitHub",
          "phase": "pre-release",
          "config": {
            "file": ".github/workflows/integration.yaml",
            "path": "$.jobs.integration.steps[?@.name=='Run integration tests']"
          }
        },
        {
          "checkTypes": ["e2e"],
          "provider": "GitHub",
          "phase": "release",
          "config": {
            "file": ".github/workflows/e2e.yaml",
            "path": "$.jobs.e2e"
          }
        },
        {
          "checkTypes": ["smoke"],
          "provider": "GitHub",
          "phase": "main",
          "config": {
            "file": ".github/workflows/smoke.yaml",
            "path": "$.jobs.smoke"
          }
        }
      ]
    }
  ]
}
