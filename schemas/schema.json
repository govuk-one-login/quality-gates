{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "root",
  "description": "An annotation of existing commands that are used as checks in quality gates for the GOVUK One Login programme",
  "examples": [
    {
      "services": [
        {
          "serviceTag": "service-name",
          "qualityGates": [
            {
              "checkTypes": ["code style and linting"],
              "provider": "GitHub",
              "phase": "pre-merge",
              "config": {
                "file": ".github/workflows/check-code-quality.yaml",
                "name": "Run pre-commit"
              }
            }
          ]
        }
      ]
    }
  ],
  "properties": {
    "services": {
      "$ref": "#/$defs/services"
    }
  },
  "$defs": {
    "check": {
      "properties": {
        "checkTypes": {
          "$ref": "#/$defs/check-type"
        },
        "phase": {
          "items": {
            "type": "string",
            "oneOf": [
            {
              "enum": [
                "pre-merge",
                "pre-upload",
                "build",
                "staging",
                "production",
                "integration"
              ]
            },
            {
              "enum": [
                "pre-develop",
                "develop",
                "pre-release",
                "release",
                "main"
              ]
            },
            {
              "enum": [
                "pre-merge",
                "pre-release"
              ]
            }
          ]
          }
        },
        "provider": {
          "enum": [
            "GitHub",
            "Stack Orchestrator"
          ]
        },
        "config": {
          "$ref": "#/$defs/check-config"
        }
      },
      "required": [
        "checkTypes",
        "phase",
        "provider",
        "config"
      ]
    },
    "check-config": {
      "type": "object",
      "properties": {
        "file": {
          "type": "string"
        },
        "path": {
          "description": "JMESPath compatible expression to identify relevant property or node",
          "type": "string"
        }
      },
      "required": [
        "file"
      ]
    },
    "check-type": {
      "type": "array",
      "description": "List of quality checks as documented, plus emergent checks",
      "items": {
        "type": "string",
        "oneOf": [
          {
            "enum": [
              "accessibility",
              "canary",
              "code quality",
              "code style and linting",
              "component",
              "contract",
              "cross service integration",
              "data compatibility",
              "e2e",
              "neighbour",
              "new feature",
              "product",
              "regression",
              "secret scanning",
              "sensitive data scanning",
              "smoke",
              "stack",
              "system",
              "unit test coverage",
              "unit",
              "visual regression",
              "vulnerability detection",
              "manual",
              "integration"
            ]
          }
        ]
      }
    },
    "quality-gate": {
      "$ref": "#/$defs/check"
    },
    "service": {
      "required": [
        "qualityGates",
        "serviceTag"
      ],
      "properties": {
        "qualityGates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/quality-gate"
          }
        },
        "serviceTag": {
          "type": "string"
        }
      }
    },
    "services": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/service"
      }
    }
  }
}
